# ===== AI 算法服务环境配置 =====
# 复制本文件为 .env 后填写真实值：cp .env.example .env

# ---------- LLM 厂商配置 ----------
# 厂商：qwen（通义千问，默认）/ deepseek / zhipu / openai
LLM_PROVIDER=qwen

# API Key（通义千问 DashScope Key）
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Base URL（OpenAI 兼容端点）
# - 通义千问：https://dashscope.aliyuncs.com/compatible-mode/v1
# - DeepSeek：https://api.deepseek.com/v1
# - 智谱 GLM：https://open.bigmodel.cn/api/paas/v4
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名
# - 通义千问：qwen-plus / qwen-turbo
# - DeepSeek：deepseek-chat
# - 智谱 GLM：glm-4-flash
LLM_MODEL=qwen-plus

# ---------- 调用参数 ----------
# 超时（秒）
LLM_TIMEOUT=30

# 最大重试次数
LLM_MAX_RETRY=2

# 温度（0-1，越大越多样，出题推荐 0.7）
LLM_TEMPERATURE=0.7

# 单次最大输出 token
LLM_MAX_TOKENS=4000

# ---------- 服务配置 ----------
# AI 服务监听端口（后端通过此端口调用）
AI_SERVICE_PORT=8001

# 允许跨源的后端地址（开发环境）
AI_CORS_ORIGINS=http://localhost:5173,http://localhost:8000
