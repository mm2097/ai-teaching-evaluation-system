# 应用配置
APP_NAME=AI 教学评价系统
APP_VERSION=0.1.0

# 数据库 (默认 SQLite,文件会在 backend/ 下生成)
# 切换 PostgreSQL: postgresql://user:pass@localhost:5432/dbname
DATABASE_URL=sqlite:///./app.db

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ===== 向量嵌入 API 配置（RAG 升级）=====
# 推荐 Silicon Flow（免费额度 + BGE 中文最佳 + OpenAI 兼容）
# 注册 https://siliconflow.cn 获取 Key
# 留空则自动回退 SQL 匹配（TF-IDF），不影响出题功能
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIM=1024
CHROMA_PERSIST_PATH=./chroma_data
